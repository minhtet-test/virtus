[app]
# App နာမည်
title = KoCLay Master
# Package နာမည်
package.name = koclay
package.domain = org.test
# Source code ရှိတဲ့ နေရာ
source.dir = .
source.include_exts = py,png,jpg,kv,atlas
# App Version
version = 1.0
# လိုအပ်တဲ့ Python Libraries များ (ဒီမှာ requests ထည့်ပေးရပါမယ်)
requirements = python3,kivy,requests,urllib3
# Android Screen 
orientation = portrait
